## Since 2015, the number of children going to non-parents generally rises and falls along with the overall number of children entering the county. However, in some quarters, all of the children go to non-parent sponsors, including most recently in 2022.

### Visualization 2: Line chart of change over time

```{r chartB_line, eval=TRUE, message=FALSE, warning=FALSE}

# organizing the data to create the line chart
nonparent_q <- mason_mc %>%
  filter(!is.na(childs_date_of_release), sponsor_category %in% 1:3) %>%
  mutate(qtr = floor_date(as.Date(childs_date_of_release), "quarter"),
         is_non_parent = sponsor_category != 1) %>%
  group_by(qtr) %>%
  summarise(non_parent_count = sum(is_non_parent), total = n(), .groups = "drop")

# plotting and creating the visual in ggplot
pB <- ggplot(nonparent_q, aes(qtr, non_parent_count)) +
  geom_line(linewidth = 1.2, color = "#2b6cb0") +
  geom_point(size = 1.8, color = "#2b6cb0") +
  geom_line(aes(y = total), color = "grey70", linetype = "dashed") +
  geom_point(
    data = subset(nonparent_q, non_parent_count == total),
    aes(y = non_parent_count),
    color = "#02075d",
    size = 3
  ) +
  labs(
    title = "Kids placed with non-parent sponors over time",
        subtitle= "Shown in comparison to overall placements (grey)",
    x = "Years divided quarterly",
    y = "Number of kids",
    caption = "Source: U.S. HHS (via NYT release), analysis by Jessica Baugh
    *One child had no sponsor category"
  ) +
  theme_classic(base_size = 13) +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

pB
```

