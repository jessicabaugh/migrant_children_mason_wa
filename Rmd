## When migrant children come to Mason County, 60% of them do not go to parent sponsors. Most go to immediate relatives, such as a sibling, aunt, uncle or cousin.

### Visualization 1: Bar chart of sponsor types 

```{r chartA, eval=TRUE, message=FALSE, warning=FALSE}

# summarize and calculate percentage
top_sponsors_summary <- mason_mc %>%
  filter(!is.na(sponsor_category)) %>%
  group_by(sponsor_category) %>%
  summarize(kids = n()) %>%
  mutate(percent = kids / sum(kids))

# ploting and creating the visual in ggplot
pA <- top_sponsors_summary %>%
  ggplot(aes(x = sponsor_category, y = percent)) +
  geom_col(fill = "#2b6cb0") +
  scale_y_continuous(labels = scales::percent_format()) +
  scale_x_discrete(
    labels = c(
      "Parent",   
      "Immediate Relative", 
      "Other"     
    )
  ) +
  labs(
    title = "Most kids coming to Mason County aren’t released to parents",
    caption = "Source: U.S. HHS (via NYT release), analysis by Jessica Baugh
       *One child had no sponsor category",
    x = "Types of Sponsors",
    y = "Percent of Kids"
  ) +
  theme(axis.ticks.x = element_blank())

pA
```

